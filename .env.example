# AICouncil — bring your own keys
# Copy this file to .env and fill in only the keys you have.
# Missing keys = that seat is skipped automatically (the council adapts).

# ─── Minimum viable setup (R1 free tier — recommended starting point) ───
# Groq is genuinely free. Google Gemini Flash has a generous free quota.

GROQ_API_KEY=                # Get at: https://console.groq.com   (free)
GOOGLE_API_KEY=              # Get at: https://aistudio.google.com  (free quota)
OPENAI_API_KEY=              # Get at: https://platform.openai.com  ($5 free credit)

# ─── Adds R2 CONTRAST (recommended for important questions) ───
ANTHROPIC_API_KEY=           # Get at: https://console.anthropic.com  ($5 free credit)
DEEPSEEK_API_KEY=            # Get at: https://platform.deepseek.com   (cheap pay-as-you-go)
OPENROUTER_API_KEY=          # Get at: https://openrouter.ai/keys      ($1 free credit)

# ─── Adds R3 MAX SIGNAL (web-grounded answers) ───
PERPLEXITY_API_KEY=          # Get at: https://perplexity.ai/settings/api  ($5/mo free)

# ─── Optional behavior controls ───

# Cap per-run spend in USD. If a council run would exceed this, the script warns.
# Leave blank to disable.
AICOUNCIL_COST_CAP_USD=

# If set, runs are logged as JSON to this directory (creates /runs subfolder).
# Useful for building your own analytics. Leave blank for ephemeral runs.
AICOUNCIL_LOG_DIR=

# ─── Security ───
# This file should never be committed to git. The bundle ships with a .gitignore
# that excludes .env — verify it's there before pushing.
